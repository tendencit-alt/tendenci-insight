# Variáveis de ambiente do frontend (Vite)
# Copie este arquivo para .env e preencha os valores.
# Apenas variáveis prefixadas com VITE_ são expostas no browser.

# ─── Sentry (observabilidade do frontend) ───
# Crie um projeto em https://sentry.io → Settings → Client Keys (DSN)
# Sem DSN, o Sentry fica desativado silenciosamente.
VITE_SENTRY_DSN=

# ─── Supabase (gerenciado pelo Lovable Cloud — NÃO editar manualmente) ───
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=
